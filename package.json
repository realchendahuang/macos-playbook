{
  "name": "macos-playbook",
  "version": "0.1.0",
  "private": true,
  "description": "一份帮助普通人真正把 macOS 用顺手的中文实战手册。",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "vitepress dev docs --host 127.0.0.1",
    "start": "vitepress dev docs --host 127.0.0.1",
    "build": "pnpm sync:readme && vitepress build docs",
    "preview": "vitepress preview docs --host 127.0.0.1",
    "sync:readme": "node scripts/sync-readme.mjs",
    "deploy": "pnpm build && wrangler deploy"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/realchendahuang/macos-playbook.git"
  },
  "devDependencies": {
    "lucide-vue-next": "^1.0.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "wrangler": "^4.100.0"
  }
}
