{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "macos-playbook",
	"main": "./src/index.ts",
	"compatibility_date": "2026-07-10",
	"assets": {
		"directory": "./docs/.vitepress/dist",
		"binding": "ASSETS",
		"run_worker_first": [
			"/",
			"/assets/*",
			"/favicon.svg",
			"/hashmap.json",
			"/sitemap.xml",
			"/vp-icons.css"
		],
		"html_handling": "auto-trailing-slash",
		"not_found_handling": "404-page"
	},
	"routes": [
		{
			"pattern": "chendahuang.com/playbook/macos",
			"zone_name": "chendahuang.com"
		},
		{
			"pattern": "chendahuang.com/playbook/macos/*",
			"zone_name": "chendahuang.com"
		},
		{
			"pattern": "macos-playbook.chendahuang.top",
			"custom_domain": true
		}
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	}
}
